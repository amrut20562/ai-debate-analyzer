<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FAFAFA">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#7C3AED"
        android:title="Welcome!"
        android:titleTextColor="#FFFFFF"
        android:elevation="4dp"/>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:layout_marginBottom="66dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- User Summary Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/profilePic"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_profile_1"
                        android:contentDescription="Profile Pic"
                        android:background="#E5E5E5"
                        android:scaleType="centerCrop"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/userName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Arghya"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1F2121"/>

                        <TextView
                            android:id="@+id/userLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Karad, Maharashtra"
                            android:textSize="15sp"
                            android:textColor="#626C71"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Welcome/Instructional Banner -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Turn your ideas into rewards. Explore trending topics, join community debates, or post your own!"
                android:textSize="16sp"
                android:textColor="#1F2121"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginBottom="32dp"/>

            <!-- Placeholder for Main Functional Areas -->
            <Button
                android:id="@+id/postIdeaButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Post New Idea"
                android:backgroundTint="#7C3AED"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/exploreButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Explore Community"
                android:backgroundTint="#C4B5FD"
                android:textColor="#1F2121"/>

        </LinearLayout>
    </ScrollView>



</androidx.coordinatorlayout.widget.CoordinatorLayout>
