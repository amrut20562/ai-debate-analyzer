<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clay_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 🔥 PREMIUM HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="@drawable/profile_header_gradient"
            android:padding="16dp"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:padding="10dp"
                android:background="@drawable/clay_circle_button"
                android:src="@drawable/ic_back_arrow"
                android:tint="#FFFFFF"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Post New Idea"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- 🌟 FORM CONTAINER -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
       >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Owner -->
                <TextView
                    style="@style/profileLabel"
                    android:text="Owner Name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/ownerNameInput"
                    style="@style/profileInput"
                    android:hint="Enter your name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName" />

                <!-- Title -->
                <TextView
                    style="@style/profileLabel"
                    android:text="Idea Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/ideaTitleInput"
                    style="@style/profileInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter idea title" />

                <!-- Description -->
                <TextView
                    style="@style/profileLabel"
                    android:text="Description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/ideaDescriptionInput"
                    style="@style/profileInput"
                    android:layout_height="120dp"
                    android:gravity="top"
                    android:layout_width="match_parent"
                    android:hint="Describe your idea..."
                    android:inputType="textMultiLine" />

                <!-- Budget -->
                <TextView
                    style="@style/profileLabel"
                    android:text="Budget (₹)"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/budgetInput"
                    style="@style/profileInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter budget amount"
                    android:inputType="numberDecimal" />

                <!-- Category -->
                <TextView
                    style="@style/profileLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category" />

                <Spinner
                    android:id="@+id/categorySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_glow"
                    android:padding="12dp"
                    android:layout_marginBottom="20dp" />

                <!-- 🗺️ MAP SECTION -->
                <TextView
                    style="@style/profileLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Location on Map" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="10dp">

                    <fragment
                        android:id="@+id/mapFragment"
                        android:name="com.google.android.gms.maps.SupportMapFragment"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/selectedLocationText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap on map to select location"
                    android:textSize="12sp"
                    android:textColor="#8A8F98"
                    android:gravity="center"
                    android:layout_marginBottom="28dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 🚀 PREMIUM CTA -->
        <androidx.cardview.widget.CardView
            android:id="@+id/proceedToPaymentButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Proceed to Payment"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/button_glow" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>