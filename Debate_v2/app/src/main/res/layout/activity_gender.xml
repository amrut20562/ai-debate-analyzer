<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Status Bar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9:41"
            android:textSize="14sp"
            android:textColor="#1F2121"
            android:layout_weight="1" />



    </LinearLayout>

    <!-- Progress Bar -->
    <View
        android:id="@+id/progressBar"
        android:layout_width="100dp"
        android:layout_height="4dp"
        android:layout_below="@id/statusBar"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:background="#7C3AED" />

    <!-- Back Button -->
    <ImageView
        android:id="@+id/backButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_below="@id/progressBar"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_back_arrow"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Back button" />

    <!-- Main Content -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/backButton"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <!-- Question Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What's your gender?"
            android:textSize="32sp"
            android:textColor="#1F2121"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <!-- Woman Option -->
        <androidx.cardview.widget.CardView
            android:id="@+id/womanOption"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="1dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Woman"
                android:textSize="16sp"
                android:textColor="#1F2121"
                android:gravity="center"
                android:background="#FFFFFF" />

        </androidx.cardview.widget.CardView>

        <!-- Man Option -->
        <androidx.cardview.widget.CardView
            android:id="@+id/manOption"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="1dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Man"
                android:textSize="16sp"
                android:textColor="#1F2121"
                android:gravity="center"
                android:background="#FFFFFF" />

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/othersOption"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="1dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Other"
                android:textSize="16sp"
                android:textColor="#1F2121"
                android:gravity="center"
                android:background="#FFFFFF" />

        </androidx.cardview.widget.CardView>


    </LinearLayout>

    <!-- Show on Profile Checkbox -->
    <LinearLayout
        android:id="@+id/showProfileContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/nextButton"
        android:layout_marginStart="28dp"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/showGenderCheckbox"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:button="@drawable/checkbox_selector"
            android:checked="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Show my gender on my profile"
            android:textSize="14sp"
            android:textColor="#626C71"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Next Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/nextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="2dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E5E5E5"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next"
                android:textSize="16sp"
                android:textColor="#1F2121"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_right_gray"
                android:contentDescription="Next arrow" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>
