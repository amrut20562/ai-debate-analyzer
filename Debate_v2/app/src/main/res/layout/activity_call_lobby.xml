<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Gradient Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_glass_gradient" />

    <!-- Glass Card Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="28dp"
        android:layout_margin="24dp"
        android:background="@drawable/bg_glass_card"
        android:elevation="10dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvJoinPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join the group call?"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Join Button (Primary - Clay Style) -->
        <Button
            android:id="@+id/btnJoinCall"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Join Call"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_clay_primary"
            android:elevation="6dp" />

        <!-- Cancel Button (Secondary Glass) -->
        <Button
            android:id="@+id/btnCancelCall"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textColor="#333333"
            android:background="@drawable/bg_glass_button"
            android:elevation="4dp" />

    </LinearLayout>

</FrameLayout>