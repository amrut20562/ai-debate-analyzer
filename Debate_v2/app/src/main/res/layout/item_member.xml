<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    android:background="@android:color/transparent">

    <!-- CLAY EFFECT INSIDE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/clay_card">

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/clay_circle_button" />

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/memberAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_profile_1" />

            <View
                android:id="@+id/onlineIndicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/online_glow_indicator"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/memberName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Member Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1F2121" />

            <TextView
                android:id="@+id/memberStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Online"
                android:textSize="12sp"
                android:textColor="#4CAF50" />

        </LinearLayout>

        <!-- Chat -->
        <androidx.cardview.widget.CardView
            android:id="@+id/chatButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Chat"
                android:textSize="14sp"
                android:textColor="#7C3AED"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:background="@drawable/clay_pill_button" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.cardview.widget.CardView>