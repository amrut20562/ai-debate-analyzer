<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/clay_bottom_sheet_bg">

    <!-- Drag Handle (Premium) -->
    <View
        android:layout_width="50dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/drag_handle_glow" />

    <!-- Client Info Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        android:background="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/clay_card_inner">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/popupClientAvatar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_profile_1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/popupClientName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Client Name"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1F2121" />

                <TextView
                    android:id="@+id/popupPostDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Posted 2 hours ago"
                    android:textSize="12sp"
                    android:textColor="#8A8A8A" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Idea Title -->
    <TextView
        android:id="@+id/popupIdeaTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Idea Title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:layout_marginBottom="6dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/popupDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This is the description of the idea..."
        android:textSize="14sp"
        android:textColor="#6E6E6E"
        android:lineSpacingExtra="3dp"
        android:maxLines="4"
        android:ellipsize="end"
        android:layout_marginBottom="18dp" />

    <!-- Stats (ONLY JOINED - ONLINE REMOVED) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_people_small"
            app:tint="#7C3AED" />

        <TextView
            android:id="@+id/popupJoinedCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24 joined"
            android:textSize="14sp"
            android:textColor="#6E6E6E"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- JOIN BUTTON (GRADIENT + GLOW) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/popupJoinButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="6dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/popupJoinButtonText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Join"
                android:textSize="16sp"
                android:textColor="#111111"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/glass_button_bg" />
        </androidx.cardview.widget.CardView>

        <!-- OPEN BUTTON (GLASS STYLE) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/popupOpenButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="4dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Open"
                android:textSize="16sp"
                android:textColor="#7C3AED"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/glass_button_bg" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>